includes:
    # Grandfather list of pre-existing level-7/8 issues (mostly
    # PDOStatement|false and string|false unguarded calls). Each PHP
    # layer split in docs/PLAN_php_layer_split.md Tiers 2–6 shrinks
    # this file; Tier 6.1 cleared most missingType.iterableValue
    # entries and Tier 6.2 raised the level from 7 to 8. Regenerate
    # with `composer baseline`.
    - phpstan-baseline.neon

parameters:
    level: 8
    paths:
        - php
    excludePaths:
        # tests/ and vendor/ aren't always present in fresh checkouts
        # (e.g. before composer install runs). Mark them optional so
        # PHPStan 2.x doesn't bail on a missing path.
        - tests (?)
        - vendor (?)
    # PHP 8.4 target — matches composer.json.
    phpVersion: 80400
