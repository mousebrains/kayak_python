{
  "$schema": "https://biomejs.dev/schemas/2.4.11/schema.json",
  "files": {
    "includes": [
      "static/**/*.js",
      "static/**/*.css",
      "src/kayak/web/static/**/*.js",
      "src/kayak/web/static/**/*.css",
      "!static/leaflet.*"
    ]
  },
  "formatter": {
    "enabled": false
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "complexity": {
        "useArrowFunction": "off"
      },
      "style": {
        "useTemplate": "off",
        "noDescendingSpecificity": "off",
        "useDefaultParameterLast": "off"
      },
      "suspicious": {
        "noGlobalIsNan": "off",
        "noRedundantUseStrict": "off",
        "noVar": "error"
      },
      "correctness": {
        "noInnerDeclarations": "off"
      }
    }
  },
  "javascript": {
    "globals": ["self", "caches", "clients", "L"]
  }
}
