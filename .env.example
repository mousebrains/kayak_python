# SQLite database URL
DATABASE_URL=sqlite:///home/pat/DB/kayak.db

# PHP reads this path directly (set via nginx fastcgi_param or PHP-FPM pool env)
SQLITE_PATH=/home/pat/DB/kayak.db

# Data pipeline settings
FETCH_TIMEOUT=300
FETCH_USER_AGENT=kayak/1.0

# Output directory for generated HTML/CSV/text (default: public_html/ in repo)
# OUTPUT_DIR=/home/pat/public_html

# Site URL used in generated pages
# SITE_URL=http://levels.wkcc.org

# HTTP Basic Auth credentials for the reach editor (php/edit.php)
# Leave unset to disable editing
# EDIT_USER=admin
# EDIT_PASSWORD=change-me-in-production

# --- Editor / Comment feature (Phase 1) ---
# When set to 1, enables the public Comment flow: /login.php, /auth.php,
# /logout.php, /account.php, and the Comment/Login links in the nav bar.
# Leave unset (or "0") to keep the feature invisible.
# EDITOR_FEATURE=0

# hCaptcha — required in production to deter magic-link spam. Leave both
# unset in dev to bypass captcha verification. Register a site at
# https://dashboard.hcaptcha.com and paste keys here.
# HCAPTCHA_SITE_KEY=
# HCAPTCHA_SECRET=

# From: address on outgoing mail. Defaults to noreply@<hostname>.
# MAIL_FROM=noreply@levels.wkcc.org

# For dev: write magic-link emails to files under this directory instead
# of calling mail(). Remove in production.
# MAIL_DUMP_DIR=/tmp/kayak-mail
