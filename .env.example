# SQLite database URL (four slashes before the absolute path)
DATABASE_URL=sqlite:////home/pat/DB/kayak.db

# PHP fallback only: PHP resolves the DB path from `database_path` in the
# runtime-config JSON (written by `levels emit-config`); SQLITE_PATH is the
# fallback when that key is absent (settable via the PHP-FPM pool env —
# nginx no longer forwards it, see conf/snippets/levels-common.conf).
SQLITE_PATH=/home/pat/DB/kayak.db

# Data pipeline settings
FETCH_TIMEOUT=300
FETCH_USER_AGENT=kayak/1.0

# Output directory for generated HTML/CSV/text.
#
# DEFAULT (unset): BASE_DIR/public_html — collides with the repo's
# public_html/ tracked symlinks and may drop stray build artifacts into
# static/. NOT recommended for active development.
#
# RECOMMENDED on dev boxes: set to a non-repo path (commit-clean):
#   OUTPUT_DIR=/home/<user>/public_html_dev
# Then (PHP pages 500 without a runtime config — see README Quick Start):
#   levels build && levels emit-config --out ~/.config/kayak/runtime-config.json
#   KAYAK_CONFIG_PATH=~/.config/kayak/runtime-config.json \
#       php -S localhost:8000 -t /home/<user>/public_html_dev
#
# Production sets this to the live nginx docroot (see deploy/SETUP.md § 3 "Environment file"):
#   OUTPUT_DIR=/home/pat/public_html

# Site URL used in generated pages and magic-link emails
# SITE_URL=https://levels.wkcc.org

# --- Editor / Comment feature (Phase 1) ---
# When set to 1, enables the public Comment flow: /login.php, /auth.php,
# /logout.php, /account.php, and the Comment/Login links in the nav bar.
# Leave unset (or "0") to keep the feature invisible.
# EDITOR_FEATURE=0

# Cloudflare Turnstile — required in production to deter magic-link
# spam. Leave both unset in dev to bypass captcha verification. Register
# a site at https://dash.cloudflare.com (Turnstile section) and paste
# keys here.
# TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET=

# From: address on outgoing mail. Defaults to noreply@<hostname>.
# MAIL_FROM=noreply@levels.wkcc.org

# For dev: write magic-link emails to files under this directory instead
# of calling mail(). Remove in production.
# MAIL_DUMP_DIR=/tmp/kayak-mail
