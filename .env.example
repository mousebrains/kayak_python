# Database URL - SQLite for development, MySQL for production
# SQLite (default for development):
DATABASE_URL=sqlite:///../DB/kayak.db

# MySQL (production on DreamHost):
# DATABASE_URL=mysql+pymysql://levels:Deschutes@mysql.wkcc.dreamhosters.com/levels

# Flask settings
FLASK_SECRET_KEY=change-me-in-production
FLASK_DEBUG=1

# Data pipeline settings
FETCH_TIMEOUT=300
FETCH_USER_AGENT=kayak/1.0
