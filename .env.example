# SQLite database URL (four slashes before the absolute path)
DATABASE_URL=sqlite:////var/lib/kayak/kayak.db

# PHP fallback only: PHP resolves the DB path from `database_path` in the
# runtime-config JSON (written by `levels emit-config`); SQLITE_PATH is the
# fallback when that key is absent (settable via the PHP-FPM pool env —
# nginx no longer forwards it, see conf/snippets/levels-common.conf).
SQLITE_PATH=/var/lib/kayak/kayak.db

# Data pipeline settings
FETCH_TIMEOUT=300
FETCH_USER_AGENT=kayak/1.0

# Output directory for generated HTML/CSV/text.
#
# DEFAULT (unset): BASE_DIR/public_html — collides with the repo's
# public_html/ tracked symlinks and may drop stray build artifacts into
# static/. NOT recommended for active development.
#
# RECOMMENDED on dev boxes: set to a non-repo path (commit-clean):
#   OUTPUT_DIR=/tmp/kayak-public-html-dev
# Then (PHP pages 500 without a runtime config — see README Quick Start):
#   levels build && levels emit-config --out ~/.config/kayak/runtime-config.json
#   KAYAK_CONFIG_PATH=~/.config/kayak/runtime-config.json \
#       php -S localhost:8000 -t /tmp/kayak-public-html-dev
#
# Production sets this to the live nginx docroot (see deploy/SETUP.md § 3 "Environment file"):
#   OUTPUT_DIR=/var/www/kayak

# Staging dir for build-external generated static inputs — today only the OSMB
# hazard/access GeoJSON from `levels fetch-osmb`, which `levels build` then
# copies into OUTPUT_DIR/static. Committed web assets (map.js, leaflet, …) ship
# inside the package at src/kayak/web/static/ and are NOT configured here.
# DEFAULT (unset): BASE_DIR/var/osmb (gitignored). Override to a non-repo path
# in production if you prefer; the kayak-fetch-osmb.service ReadWritePaths must
# then match.
# OSMB_DIR=/var/cache/kayak/osmb

# Dataset root — the club-specific dataset (the *.csv + reaches*.json the
# metadata flow treats as the source of truth). Clone a dataset repository and
# point this at it. DEFAULT (unset): BASE_DIR/data/db (no CSVs live there post data-repo
# split, so set this in any real deployment).
#   DATASET_DIR=/srv/kayak_data
# DEPRECATED: METADATA_DIR is the old name for this var — still honored for one
# release (with a deprecation warning); rename it to DATASET_DIR. Note: a
# METADATA_DIR set in THIS file also participates in the both-set conflict check
# (it's loaded into the env before the check runs), so exporting DATASET_DIR to a
# DIFFERENT path while this file still sets METADATA_DIR is a hard error — rename
# it here promptly to avoid the surprise.

# Site URL used in generated pages and magic-link emails
# SITE_URL=https://levels.example.org

# --- Editor / Comment feature (Phase 1) ---
# When set to 1, enables the public Comment flow: /login.php, /auth.php,
# /logout.php, /account.php, and the Comment/Login links in the nav bar.
# Leave unset (or "0") to keep the feature invisible.
# EDITOR_FEATURE=0

# Cloudflare Turnstile — required in production to deter magic-link
# spam. Leave both unset in dev to bypass captcha verification. Register
# a site at https://dash.cloudflare.com (Turnstile section) and paste
# keys here.
# TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET=

# From: address on outgoing mail. Defaults to noreply@<hostname>.
# MAIL_FROM=noreply@example.org

# Reply-To defaults to noreply@<SITE_URL host>. Override when replies
# should go to a different public mailbox.
# MAIL_REPLY_TO=help@example.org

# For dev: write magic-link emails to files under this directory instead
# of calling mail(). Remove in production.
# MAIL_DUMP_DIR=/tmp/kayak-mail
