namespace Parsers {
  USGS::USGS(const Curl& curl,
             const bool qVerbose,
             const bool qDryRun,
	     DataDB& db)
    : Parse(curl.url(), qVerbose, qDryRun, db), 
      mState(0)
  {
    initParameters(); 
    serveUpLines(curl.str());
  } 
  
  
  std::string
  USGS::getString(const Tokenize& tokens,
  		  const std::string& field) const
  {
    tMap::const_iterator it(mFields.find(field));
  
    if (it == mFields.end()) {
      std::cerr << "Field '" << field << "' not found in map for " << mURL << std::endl;
      return std::string();
    }
  
    const std::string::size_type offset(it->second.first);
    const std::string::size_type len(it->second.second);

    if (offset >= tokens.size())
      return std::string();

    std::string result(tokens[offset]);
 
    for (std::string::size_type i = offset + 1; i < (offset + len); ++i)
      result += " " + tokens[i];
 
    return result;
  }
  
  bool
  USGS::line(const std::string& l)
  {
    Tokenize tokens(l);
  
    if (mDebug)
      std::cout << mState << " " << l << std::endl;
  
    switch (mState) {
    case 0:
      if ((tokens.size() > 2) && 
          (tokens[0] == "#") && 
          (tokens[1] == "Retrieved:")) {
        mTimeZone(tokens[tokens.size() - 1]);
        ++mState;
      }
      break;
    case 1:
      if (tokens.size() && (tokens[0] == "agency_cd")) {
        mColumns = tokens.tokens();
        ++mState;
      }
      break;
    case 2:
      if (tokens.size() != mColumns.size()) {
        std::cerr << "Column names had " << mColumns.size() << " fields, while there are "
  		<< tokens.size() << " widths" << std::endl;
        mState = 0;
        break;
      }
  
      for (Tokenize::size_type i = 0, offset = 0; i < tokens.size(); ++i) {
        const std::string& width(tokens[i]);
        const std::string& id(mColumns[i]);
        int nColumns(1);
  
        if ((width.size() > 1) && (width.substr(width.size() - 1) == "d")) // A date
  	  nColumns = 2;
  
        mFields.insert(std::make_pair(id, std::make_pair(offset, nColumns)));
        offset += nColumns;
      }
      ++mState;
      break;
    case 3:
      {
        const std::string station(getString(tokens, "site_no"));
        const time_t now(time(0));
        const std::string& timeZone(getString(tokens, "result_tz_cd"));
        const std::string& timeStr(getString(tokens, "result_dt"));

        time_t time(0);
        if (timeZone.empty()) {
          time = toDate(timeStr);
        } else {
          time = toDate(timeStr, timeZone);
        }
        const int parameter(toInt(getString(tokens, "parameter_cd")));
        const double value(toDouble(getString(tokens, "result_va"), false));

        for (int count(0); (count < 2) && (time != -1) && (now < time); 
             ++count) { 
            // USGS puts 23:00 as the next day, and even sometimes publishes
            // 22:?? as two days into the future
          time -= 24 * 3600;
        }

        if (!station.empty() && (time != -1) && finite(value)) {
  	tParameter::const_iterator it(parameters.find(Parameter(parameter)));
  	if (it == parameters.end()) {
	  ;
  	  // std::cerr << "Unrecognized parameter " << parameter
  		    // << " for " << mURL << std::endl;
  	} else if(it->valid(value)) {
  	  const std::string& type(it->dbKey());
  	  dumpToDatabase(station, type, time, it->value(value));
  	}
        }
      }
      break;
    default:
      std::cerr << "Unsupported state(" << mState << ") for url=" << mURL << std::endl;
    }
  
    return true;
  }
}
