namespace {
  class Parameter {
  private:
    int mType;
    std::string mKey;
    std::string mDBkey;

    double mMin;
    double mSlope;
    double mIntercept;
    double mRound;
  public:
    explicit Parameter(const int type) : mType(type) {}

    Parameter(int type, const std::string& key) 
      : mType(type), mKey(key), mMin(-1e10), mSlope(1), mIntercept(0), mRound(0) {}
    Parameter(int type, const std::string& key, const std::string& dbKey)
      : mType(type), mKey(key), mDBkey(dbKey), mMin(-1e30), mSlope(1), mIntercept(0), mRound(0) {}
    Parameter(int type, const std::string& key, const std::string& dbKey, double min)
      : mType(type), mKey(key), mDBkey(dbKey), mMin(min), mSlope(1), mIntercept(0), mRound(0) {}
    Parameter(int type, const std::string& key, const std::string& dbKey, double a, double b, 
              double round)
      : mType(type), mKey(key), mDBkey(dbKey), mMin(-1e30), mSlope(a), mIntercept(b), 
        mRound(round) {}

    virtual ~Parameter() {}

    int type() const {return mType;}
    const std::string& key() const {return mKey;}
    const std::string& dbKey() const {return mDBkey;}

    bool valid(const double v) const {return !mDBkey.empty() && (v > mMin);}

    double value(const double v) const {
      const double a(v * mSlope + mIntercept);
      return mRound ? (rint(a / mRound) * mRound) : a;
    }

    bool operator < (const Parameter& rhs) const {return mType < rhs.mType;}
  };

  class Temperature : public Parameter {
  public:
    Temperature(const int type, const std::string& key) : Parameter(type, key, "temperature") {}
  };

  class Celsius : public Parameter {
  public:
    Celsius(const int type, const std::string& key) : Parameter(type, key, "temperature", 
                                                                1.8, 32, 0.1)
    {}
  };

  class Gage : public Parameter {
  public:
    Gage(const int type, const std::string& key) : Parameter(type, key, "gage") {}
  };

  class Flow : public Parameter {
  public:
    Flow(const int type, const std::string& key) : Parameter(type, key, "flow", 0) {}
  };

