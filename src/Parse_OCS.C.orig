#include <Parse_OCS.H>
#include <File.H>
#include <Tokenize.H>
#include <Convert.H>
#include <String.H>
#include <Curl.H>
#include <iostream>

namespace {
  const std::string ws(" \t\n*");

  std::string mkName(std::string name) {
    String::trimInPlace(name, ws);

    for (std::string::size_type pos = 0, index; 
        (index = name.find_first_of(ws , pos)) != name.npos;) {
      const std::string::size_type i(name.find_first_not_of(ws, index));
      name.replace(index, i - index, "_");
      pos = index + 1;
    }
    return name; 
  }
}

namespace Parsers {
  OCS::OCS(const Curl& curl,
           const bool qVerbose,
           const bool qDryRun,
	   DataDB& db)
    : Parse(curl.url(), qVerbose, qDryRun, db),
      mState(0),
      mColLocation(0),
      mColFlow(0),
      mColStage(0),
      mColChange(0)
  { 
    serveUpLines(curl.str()); 
  }

  bool
  OCS::line(const std::string& l)
  {
    if (mDebug)
      std::cout << mState << " " << l << std::endl;

    switch (mState) {
    case 0:
      {
        Tokenize tokens(l);
	Tokenize::const_iterator it(tokens.find("NATIONAL"));
	if ((it != tokens.end()) && 
	    ((++it != tokens.end()) && (*it == "WEATHER")) &&
	    ((++it != tokens.end()) && (*it == "SERVICE")))
	  ++mState;
      }
      break;
    case 1:
      {
        if (l.size() > 4 && l[3] == ' ') {
          if ((mTime = toDate("0" + l, true)) == (time_t) -1)
            mState = 0;
          else
            ++mState;
        } else if ((mTime = toDate("0" + l, true)) == (time_t) -1)
          mState = 0;
        else
          ++mState;
      }
      break;
    case 2:
      if (l.substr(0, 5) == "RIVER") {
        ++mState;
	mColLocation = l.find("LOCATION");
        mColFlow = l.find("FLOW");
        mColStage = l.find("STAGE");
        mColChange = l.find("24 HR");
      }
      break;
    case 3:
      if (l.find("RANGE OF THE PORTLAND HARBOR") != l.npos) {
        mState = 0;
        break;
      }
      if (l.size() < mColFlow) 
        mName = mkName(l.substr(0, mColFlow));
      else {
        std::string river(mkName(l.substr(0, mColLocation))); 
        const std::string location(mkName(l.substr(0, mColFlow)));
        std::string station;

        if (!river.empty()) {
          station = location;
          mName = river;
        } else 
          station = mName.empty() ? location : (mName + "_" + location);

        std::string flow(l.size() <= mColFlow ? "" : l.substr(mColFlow, mColStage - mColFlow)); 
        std::string::size_type cfs(flow.find("CFS"));

        if (cfs != flow.npos) {
          double multiplier(1);
          if (flow.find("KCFS") != flow.npos) {
            multiplier = 1000;
            flow = String::trim(flow.substr(0, cfs - 1));
          } else
            flow = String::trim(flow.substr(0, cfs));

          double value;
          std::istringstream iss(flow);
          if ((iss >> value) && ((size_t) iss.tellg() == flow.size()))  {
            dumpToDatabase(station, DataDB::FLOW, mTime, value);
	    std::cout << "station=" << station << " flow mTime " << mTime << " val " << value << std::endl;
	  }
        }
       
        std::string stage(l.size() <= mColStage ? "" : l.substr(mColStage, mColChange - mColStage));
        std::string::size_type ft(stage.find("FT"));

        if (ft != stage.npos) {
          stage = String::trim(stage.substr(0, ft));
          double value;
          std::istringstream iss(stage);
          if ((iss >> value) && ((size_t) iss.tellg() == stage.size()))  {
            dumpToDatabase(station, DataDB::GAGE, mTime, value);
	    std::cout << "station=" << station << " gage mTime " << mTime << " val " << value << std::endl;
	  }
        }
      }
      break;
    default:
      std::cerr << "Unrecognized state " << mState << " " << mURL << std::endl;
      return false;
    }
    return true;
  }
}
