# conf/sites/levels-mousebrains-com
# Deployed to /etc/nginx/sites-available/levels-mousebrains-com.
#
# Historical hostname for the kayak project. Permanent 301 to the
# canonical levels.wkcc.org as of 2026-05-19. The cert primary CN is
# still levels.mousebrains.com (subject of the shared 3-SAN cert at
# /etc/letsencrypt/live/levels.mousebrains.com/), so this vhost owns
# the cert paths; the other two vhosts inherit the same files.
#
# Path + query are preserved so old bookmarks land on the matching
# URL under levels.wkcc.org. After ~6-12 months of low legacy traffic
# in /var/log/nginx/levels-mousebrains.access.log, the vhost can be
# decommissioned entirely (return 410 or drop the vhost).

# Redirect HTTP → HTTPS so the 301 response carries HSTS.
server {
    listen 80;
    listen [::]:80;
    server_name levels.mousebrains.com;
    return 301 https://$host$request_uri;
}

server {
    listen [::]:443 ssl ipv6only=on; # managed by Certbot
    listen 443 ssl; # managed by Certbot
    http2 on;

    ssl_certificate /etc/letsencrypt/live/levels.mousebrains.com/fullchain.pem; # managed by Certbot
    ssl_certificate_key /etc/letsencrypt/live/levels.mousebrains.com/privkey.pem; # managed by Certbot
    include /etc/letsencrypt/options-ssl-nginx.conf; # managed by Certbot
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem; # managed by Certbot

    # OCSP stapling intentionally NOT enabled: Let's Encrypt's ISRG/E7 certs
    # no longer include an OCSP responder URL (CA/B Forum baseline 2024+).

    server_name levels.mousebrains.com;

    # Per-host log only — watch this file shrink as users migrate to
    # the canonical levels.wkcc.org URL.
    access_log /var/log/nginx/levels-mousebrains.access.log kayak_timed;
    error_log  /var/log/nginx/levels-mousebrains.error.log;

    # HSTS (+ a few other defensive headers) on the redirect response so
    # legacy first-time visitors still get pinned to HTTPS.
    include /etc/nginx/snippets/security-headers.conf;

    return 301 https://levels.wkcc.org$request_uri;
}
