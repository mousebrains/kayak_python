# conf/sites/levels-mousebrains-com
# Deployed to /etc/nginx/sites-available/levels-mousebrains-com.
#
# Legacy/transition hostname for the kayak project — the actual host
# that levels.wkcc.org CNAMEs to. The cert primary CN remains
# levels.mousebrains.com (subject of the shared 3-SAN cert at
# /etc/letsencrypt/live/levels.mousebrains.com/). Eventually this
# block will become a 301 redirect to levels.wkcc.org once the per-host
# access log shows legacy traffic has decayed.

# Redirect HTTP → HTTPS
server {
    listen 80;
    listen [::]:80;
    server_name levels.mousebrains.com;
    return 301 https://$host$request_uri;
}

server {
    listen [::]:443 ssl ipv6only=on; # managed by Certbot
    listen 443 ssl; # managed by Certbot
    http2 on;

    ssl_certificate /etc/letsencrypt/live/levels.mousebrains.com/fullchain.pem; # managed by Certbot
    ssl_certificate_key /etc/letsencrypt/live/levels.mousebrains.com/privkey.pem; # managed by Certbot
    include /etc/letsencrypt/options-ssl-nginx.conf; # managed by Certbot
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem; # managed by Certbot

    # OCSP stapling intentionally NOT enabled: Let's Encrypt's ISRG/E7 certs
    # no longer include an OCSP responder URL (CA/B Forum baseline 2024+).

    server_name levels.mousebrains.com;

    # Per-host log only. fail2ban jails read the levels-*.{access,error}.log
    # glob (jail.local + jail.d/kayak-edit*.conf), so adding a fourth vhost
    # later needs no fail2ban edit. Watch this file shrink as users migrate
    # to levels.wkcc.org after DNS cuts over.
    access_log /var/log/nginx/levels-mousebrains.access.log kayak_timed;
    error_log  /var/log/nginx/levels-mousebrains.error.log;

    # /_internal/ lives on the wkcc hosts (docs/done/PLAN_internal_dashboard.md Phase 2.4).
    # `SITE_URL` is levels.wkcc.org, so the magic-link login flow lands on that
    # host post-auth — mounting the dashboard here would break the round-trip.
    # `^~` overrides the regex \.php$ block from levels-common.conf, blocking
    # direct /_internal/index.php access on this legacy hostname.
    location ^~ /_internal/ {
        return 404;
    }

    include /etc/nginx/snippets/levels-common.conf;
}
