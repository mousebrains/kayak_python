# conf/sites/levels-test-wkcc-org
# Deployed to /etc/nginx/sites-available/levels-test-wkcc-org.
#
# Permanent 301 to canonical levels.wkcc.org as of 2026-05-19. When a
# separate test instance is stood up, it will use a different hostname
# (not levels-test.wkcc.org) — see docs/PLAN_three_instance_layout.md.
# Hostname kept reserved on the 3-SAN cert in case it's reclaimed later.

# Redirect HTTP → HTTPS so the 301 response carries HSTS.
server {
    listen 80;
    listen [::]:80;
    server_name levels-test.wkcc.org;
    return 301 https://$host$request_uri;
}

server {
    # ipv6only=on lives on levels-mousebrains-com (the alphabetically-first
    # vhost in sites-enabled/). nginx accepts the IPV6_V6ONLY socket option
    # exactly once per [::]:443 socket; repeating it here breaks `nginx -t`
    # with "duplicate listen options for [::]:443".
    listen [::]:443 ssl; # managed by Certbot
    listen 443 ssl; # managed by Certbot
    http2 on;

    ssl_certificate /etc/letsencrypt/live/levels.mousebrains.com/fullchain.pem; # managed by Certbot
    ssl_certificate_key /etc/letsencrypt/live/levels.mousebrains.com/privkey.pem; # managed by Certbot
    include /etc/letsencrypt/options-ssl-nginx.conf; # managed by Certbot
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem; # managed by Certbot

    # OCSP stapling intentionally NOT enabled: Let's Encrypt's ISRG/E7 certs
    # no longer include an OCSP responder URL (CA/B Forum baseline 2024+).

    server_name levels-test.wkcc.org;

    access_log /var/log/nginx/levels-test.access.log kayak_timed;
    error_log  /var/log/nginx/levels-test.error.log;

    # HSTS (+ a few other defensive headers) on the redirect response so
    # first-time visitors still get pinned to HTTPS.
    include /etc/nginx/snippets/security-headers.conf;

    return 301 https://levels.wkcc.org$request_uri;
}
