# conf/sites/levels-wkcc-org
# Deployed to /etc/nginx/sites-available/levels-wkcc-org.
#
# Primary public hostname for the kayak project. CNAMEs to
# levels.mousebrains.com at the DNS layer.
#
# Cert state during the DNS cutover window (per DNS.CHANGEOVER-fastpath.md):
# bridge with the DreamHost-issued LE cert at /etc/nginx/certs/ until DNS
# propagates (~T+3 from the A→CNAME flip), then run
#     certbot --nginx --expand --cert-name levels.mousebrains.com \
#         -d levels.mousebrains.com -d levels-test.wkcc.org -d levels.wkcc.org
# and flip these ssl_certificate paths back to
# /etc/letsencrypt/live/levels.mousebrains.com/fullchain.pem (+ privkey.pem).
# That gives a single 3-SAN cert renewed via HTTP-01, end-state matching
# the original DNS.CHANGEOVER.md target. No DNS-01 dance, no _acme-challenge
# CNAMEs at ClubExpress.

# Redirect HTTP → HTTPS
server {
    listen 80;
    listen [::]:80;
    server_name levels.wkcc.org;
    return 301 https://$host$request_uri;
}

server {
    # ipv6only=on lives on levels-mousebrains-com (the alphabetically-first
    # vhost in sites-enabled/). nginx accepts the IPV6_V6ONLY socket option
    # exactly once per [::]:443 socket; repeating it here breaks `nginx -t`
    # with "duplicate listen options for [::]:443".
    listen [::]:443 ssl; # managed by Certbot
    listen 443 ssl; # managed by Certbot
    http2 on;

    # Bridge cert during DNS cutover window — see header comment.
    # Post-cutover (~T+3): switch back to the certbot-managed 3-SAN cert at
    # /etc/letsencrypt/live/levels.mousebrains.com/.
    ssl_certificate /etc/nginx/certs/levels.wkcc.org.cert;
    ssl_certificate_key /etc/nginx/certs/levels.wkcc.org.privkey;
    include /etc/letsencrypt/options-ssl-nginx.conf; # managed by Certbot
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem; # managed by Certbot

    # OCSP stapling intentionally NOT enabled: Let's Encrypt's ISRG/E7 certs
    # no longer include an OCSP responder URL (CA/B Forum baseline 2024+).

    server_name levels.wkcc.org;

    # Per-host log only. fail2ban jails read the levels-*.{access,error}.log
    # glob (jail.local + jail.d/kayak-edit*.conf), so adding a fourth vhost
    # later needs no fail2ban edit. Once DNS cuts over, this is where the
    # bulk of traffic lands.
    access_log /var/log/nginx/levels-wkcc.access.log kayak_timed;
    error_log  /var/log/nginx/levels-wkcc.error.log;

    # /_internal/ — maintainer-only operator dashboard (docs/done/PLAN_internal_dashboard.md
    # Phase 2.4). PHP enforces auth via require_maintainer(); nginx routes the
    # two URIs and adds noindex headers. `=` exact-match beats the regex \.php$
    # in levels-common.conf without `^~`, so we don't intercept any future
    # files under /_internal/ that aren't part of this dashboard. This vhost
    # is the canonical home post-DNS-cutover (SITE_URL=levels.wkcc.org); the
    # mousebrains vhost holds a 404 guard.
    location = /_internal/ {
        rewrite ^ /_internal/index.php last;
    }
    location = /_internal/index.php {
        limit_req zone=php burst=10 nodelay;
        try_files $uri =404;
        fastcgi_pass unix:/run/php/php-fpm.sock;
        fastcgi_param SCRIPT_FILENAME $document_root$fastcgi_script_name;
        include fastcgi_params;
        add_header X-Robots-Tag "noindex, nofollow" always;
        add_header Cache-Control "no-store, private" always;
        include /etc/nginx/snippets/security-headers.conf;
    }

    include /etc/nginx/snippets/levels-common.conf;
}
