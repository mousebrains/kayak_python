# Kayak river levels — Apache configuration
# Deployed to public_html/ on DreamHost shared hosting.

DirectoryIndex index.html

# Error pages
ErrorDocument 404 /404.html

# ---------------------------------------------------------------------------
# Compression (mod_deflate) — DreamHost enables this by default but
# these directives ensure all text types are covered.
# ---------------------------------------------------------------------------
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/plain text/xml
  AddOutputFilterByType DEFLATE application/json application/javascript
  AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# ---------------------------------------------------------------------------
# Cache headers
# ---------------------------------------------------------------------------
<IfModule mod_headers.c>
  # Static HTML pages — 5 min (rebuilt by cron)
  <FilesMatch "\.(html)$">
    Header set Cache-Control "public, max-age=300"
  </FilesMatch>

  # CSS, JS, manifest, icons — 1 day (versioned by content)
  <FilesMatch "\.(css|js|json|png|ico)$">
    Header set Cache-Control "public, max-age=86400"
  </FilesMatch>

  # CSV/text data files — 5 min
  <FilesMatch "\.(csv|text)$">
    Header set Cache-Control "public, max-age=300"
  </FilesMatch>

  # SVG (plot output) — 5 min
  <FilesMatch "\.svg$">
    Header set Cache-Control "public, max-age=300"
  </FilesMatch>
</IfModule>

# ---------------------------------------------------------------------------
# MIME types
# ---------------------------------------------------------------------------
<IfModule mod_mime.c>
  AddType application/manifest+json .json
  AddType image/svg+xml .svg
</IfModule>

# ---------------------------------------------------------------------------
# PHP scripts are in the root alongside static HTML.
# No special config needed — DreamHost runs PHP 8.x by default.
# ---------------------------------------------------------------------------
