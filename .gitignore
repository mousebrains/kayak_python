.DS_Store
.claude

# Legacy system dumps to initialize this system.
legacy

obj
*.o
*.d
!deploy/fail2ban/jail.d/
!deploy/fail2ban/filter.d/
!deploy/sshd_config.d/
!deploy/sysctl.d/
!deploy/apt.conf.d/
!deploy/sudoers.d/
tpw.master.2*
tkw.*
tpw.*

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
/dist/
/build/
.venv/
*.db
*.db-shm
*.db-wal
.env
.pytest_cache/
.coverage

# `levels build` writes only a caller-supplied OUTPUT_DIR outside the repo
# (S3h / finishing-plan R4: the tracked public_html/ dev-symlink farm is gone
# and build refuses the engine/dataset trees as output). Ignore the legacy
# in-repo output locations defensively so a stale checkout or an old build
# can't dirty the worktree.
public_html/
/static/

# DB backups moved to /home/pat/backups, outside the repo (review-4 R5.6);
# kept as a defensive guard against a stray ./backups in the worktree.
backups

# Runtime-generated state (status page render, future cache files)
var/*
!var/.gitkeep
# Keep the OSMB staging dir (osmb_dir default) present so kayak-fetch-osmb's
# ReadWritePaths=.../var/osmb passes systemd's setup-time existence check on a
# fresh clone; ignore the generated osmb-*.geojson inside it.
!var/osmb/
var/osmb/*
!var/osmb/.gitkeep

# Ad-hoc audit dumps (often contain secrets from nginx -T or similar)
*.log

# PHP tooling (composer.lock is intentionally committed for deterministic installs)
vendor/
.phpunit.cache/
.phpunit.result.cache
.php-cs-fixer.cache
coverage.xml

# Stream trace data caches (NHD, OSM, merged)
OSM-cache/
NHD-cache/
Trace-cache/

# DEM/LIDAR tile cache + per-reach elevation profiles (Phase 2 gradient work)
DEM-cache/
Elevation-cache/

# Gauge station metadata cache (gauges.db — agency site-info lookups, read by
# web/build/gauges.py + the scripts/ harvesters)
Gauge-metadata-cache/

# Discovery artifacts — candidate CSVs feeding migration generators
data/discover/

# Ad-hoc research / analysis scratch
tpw/

# JS smoke-test scaffold (docs/PLAN_js_smoke_tests.md)
node_modules/
playwright-report/
test-results/
/tests/js/.cache/
