[Unit]
# Canonical drill target for the OnFailure= → kayak-notify-failure@ chain.
# Run by hand whenever notifier wiring is touched (channel additions,
# msmtp config changes, ntfy topic rotation) or as part of the Tier 4.4
# recovery drill:
#
#   sudo systemctl start kayak-fail-test.service
#
# Always exits non-zero on purpose. Intentionally outside the Phase 1.3
# heartbeat set (no ExecStartPost — pinging healthchecks.io would just
# tag a "ping then immediate fail" pattern that means nothing).
#
# See docs/PLAN_production_discipline.md Phase 1.5.
Description=Drill target — deliberately fails to verify OnFailure= chain
OnFailure=kayak-notify-failure@%n.service

[Service]
Type=oneshot
User=pat
ExecStart=/bin/false
