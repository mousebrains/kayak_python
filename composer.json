{
    "name": "kayak/php",
    "description": "PHP dynamic layer for levels.wkcc.org — tests + static analysis.",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": "^8.4",
        "ext-pdo": "*",
        "ext-pdo_sqlite": "*"
    },
    "require-dev": {
        "phpstan/phpstan": "^2",
        "phpunit/phpunit": "^11.5"
    },
    "config": {
        "sort-packages": true,
        "platform-check": false
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse --memory-limit=1G",
        "baseline": "phpstan analyse --memory-limit=1G --generate-baseline=phpstan-baseline.neon"
    }
}
