# /etc/sudoers.d/kayak-emit-config
#
# Grants user `pat` password-less sudo for ONE command: the root-owned
# runtime-config installer. scripts/deploy.sh renders the typed-config JSON
# UNPRIVILEGED (as pat) and pipes it to this wrapper, which installs it to
# /etc/kayak/runtime-config.json:
#
#     levels emit-config --dry-run | sudo -n /usr/local/sbin/kayak-install-runtime-config
#
# Why the wrapper (review-3 R1.5): the grant must NOT invoke
# /home/pat/.venv/bin/levels — that binary is writable by `pat`, so a
# compromised pat could replace it and run arbitrary code as root. Instead the
# grant runs only /usr/local/sbin/kayak-install-runtime-config, which is
# root:root 0755 (pat can't modify it) and does exactly one thing: validate the
# piped JSON and atomically install it (0640 root:www-data). pat still controls
# the config *content* (its own ~/.config) but not what executes as root, and
# there is no staging file so no symlink/TOCTOU surface.
#
# Install (on the live server, as root):
#
#     install -m 0755 -o root -g root \
#         /home/pat/kayak/deploy/kayak-install-runtime-config.sh \
#         /usr/local/sbin/kayak-install-runtime-config
#     install -m 440 -o root -g root \
#         /home/pat/kayak/deploy/sudoers.d/kayak-emit-config \
#         /etc/sudoers.d/kayak-emit-config
#     visudo -cf /etc/sudoers.d/kayak-emit-config   # validate before reload
#
# Requirements:
#   - sudoers file mode 440, owner root:root, passes `visudo -cf`
#   - the wrapper is root:root 0755 at /usr/local/sbin/kayak-install-runtime-config
#
# There is NO wildcard and no path the grant can abuse: the wrapper's only side
# effect is writing /etc/kayak/runtime-config.json (0640 root:www-data) — it
# cannot run other levels subcommands, modify systemd, or touch the database.

pat ALL=(root) NOPASSWD: /usr/local/sbin/kayak-install-runtime-config
