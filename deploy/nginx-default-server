# /etc/nginx/sites-available/default
# Drop all requests that hit the server by IP or unknown hostname.
# This silences the constant scanner noise in access.log.

server {
    listen 80 default_server;
    listen [::]:80 default_server;

    server_name _;

    access_log /var/log/nginx/blocked-access.log;

    return 444;  # close connection with no response
}

server {
    listen 443 default_server ssl;
    listen [::]:443 default_server ssl;

    server_name _;

    # Dummy cert (generated by install script)
    ssl_certificate /etc/nginx/ssl/dummy.crt;
    ssl_certificate_key /etc/nginx/ssl/dummy.key;

    access_log /var/log/nginx/blocked-access.log;

    return 444;
}
