# /etc/kayak/env — non-secret deploy-time configuration
#
# Install: sudo install -D -m 0644 -o root -g root \
#     deploy/kayak-env.example /etc/kayak/env
#
# After edits: no daemon-reload needed (EnvironmentFile content is
# re-read at each service start). kayak-*.service units are
# Type=oneshot, so the next timer firing picks up the change. A
# long-running service (none today) would need an explicit restart.
#
# KAYAK_HOME parameterizes paths under the operator's $HOME for
# kayak-*.service ExecStart= / ExecStartPost= directives and the
# helper shell scripts under systemd/ and scripts/. It CANNOT be
# used in systemd WorkingDirectory= / EnvironmentFile= /
# ReadWritePaths= — those directives do not expand env vars and the
# paths there stay literal. Each remaining literal carries a leading-
# comment annotation in its unit; see docs/PLAN_tier3_closeout.md
# § Phase 5.3 / 5.7 for the residual-count rationale.

KAYAK_HOME=/home/pat
SITE_URL=https://levels.wkcc.org

# --- Typed host config (S7/S8, Batch 4) ------------------------------------
# The schema of record for non-secret host shape (status-page knobs, backup
# policy) is kayak.host.HostConfig, read from /etc/kayak/host.yaml (override
# the location with KAYAK_HOST_CONFIG). A missing file keeps the engine
# defaults, which currently mirror this host's values.
#
# The backup shell scripts read their policy knobs from THIS env file (the
# units can't read YAML); keep them in lockstep with host.yaml when you set
# either. CAVEAT until the Batch 4C unit renderer lands: the shipped units
# sandbox-pin ReadWritePaths to the DEFAULT paths, so moving KAYAK_BACKUP_DIR
# (or host.yaml's status_output) also requires editing the matching unit's
# ReadWritePaths/--output, or systemd denies the write. Values are validated
# at deploy time (`levels validate-config`) AND by the scripts themselves
# (fail-closed; e.g. a non-positive KAYAK_OFFSITE_KEEP aborts before any
# rclone delete). Defaults shown:
#KAYAK_HOST_CONFIG=/etc/kayak/host.yaml
#KAYAK_BACKUP_DIR=/home/pat/backups
#KAYAK_OFFSITE_REMOTE=gdrive-crypt
#KAYAK_OFFSITE_KEEP=26
