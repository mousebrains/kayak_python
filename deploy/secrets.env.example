# /etc/kayak/secrets.env — runtime secrets for the PHP-FPM kayak pool.
#
# Install path and mode:
#   sudo install -D -m 0600 -o root -g www-data secrets.env /etc/kayak/secrets.env
#
# The PHP-FPM pool overlay (deploy/kayak-fpm-pool.conf) reads this file via
# EnvironmentFile and re-exports the variables to the kayak worker processes
# through env[NAME]=$NAME lines. World-readable nginx config files never see
# these values.
#
# Edit in place (not via the example file):
#   sudo -e /etc/kayak/secrets.env          # uses $EDITOR safely
#   sudo systemctl restart php-fpm          # picks up the new values
#
# Keys:
#   HCAPTCHA_SECRET — issued by hCaptcha when the site key is created.
#                     Leave empty to disable hCaptcha (dev / pre-rollout).
#   EDIT_PASSWORD   — HTTP Basic Auth password for /edit.php.
#                     Leave empty to disable edit entirely.

HCAPTCHA_SECRET=
EDIT_PASSWORD=
