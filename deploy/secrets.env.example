# /etc/kayak/secrets.env — production runtime secrets (root-only).
#
# Install path and mode:
#   sudo install -D -m 0600 -o root -g www-data secrets.env /etc/kayak/secrets.env
#
# How the values reach PHP (2026-06-03): the root-owned install wrapper
# (deploy/kayak-install-runtime-config.sh) merges this file into
# /etc/kayak/runtime-config.json on every deploy — each KEY=VALUE lands
# as lowercase(KEY) in the JSON unless the rendered config already
# carries a non-empty value. PHP reads the JSON only (T3.3 Phase 4
# removed the getenv fallback). The PHP-FPM pool overlay
# (deploy/kayak-fpm-pool.conf) still re-exports these into worker env —
# an unread legacy channel kept as defense-in-depth. World-readable
# nginx config files never see these values.
#
# Edit in place (not via the example file):
#   sudo -e /etc/kayak/secrets.env          # uses $EDITOR safely
#   # then re-run the deploy's emit|install step (or scripts/deploy.sh)
#   # so the merge lands in runtime-config.json; no php-fpm restart needed.
#
# Keys:
#   TURNSTILE_SITE_KEY — the public widget key (embedded in HTML; kept
#                        here so the whole Turnstile pair lives in one
#                        root-managed file).
#   TURNSTILE_SECRET   — issued by Cloudflare when the Turnstile site is
#                        created (dashboard.cloudflare.com → Turnstile).
#                        Leave empty to disable Turnstile (dev /
#                        pre-rollout) — empty values are not merged.
#
# Note: edit.php no longer reads EDIT_PASSWORD — maintainer edits are
# gated on the ed_sess editor-session cookie (require_maintainer()).

TURNSTILE_SITE_KEY=
TURNSTILE_SECRET=
