# conf/levels.nginx — TARGET state (post-migrate-secrets.sh + post-edit.php-auth-migration).
# Deployed to /etc/nginx/sites-available/levels on prod.
# deploy/levels is the CURRENT-LIVE snapshot; regenerate it from this file
# after the operator runs deploy/migrate-secrets.sh on prod and nginx reloads
# cleanly. Delta vs. deploy/levels today: no fastcgi_param HCAPTCHA_SECRET
# (moved to PHP-FPM pool env) and no edit-password.conf include (edit.php
# now uses ed_sess cookie auth after Phase 6 of the 2026-04-22 plan).
# 2026-05-01: hCaptcha replaced with Cloudflare Turnstile — fastcgi_param
# TURNSTILE_SITE_KEY + security-headers-turnstile.conf snippet; secret in
# /etc/kayak/secrets.env (TURNSTILE_SECRET) via the PHP-FPM pool overlay.

# Redirect HTTP → HTTPS
server {
    listen 80;
    listen [::]:80;
    # levels.wkcc.org is the canonical public name (CNAME -> levels.mousebrains.com).
    # Requires SAN expansion — certbot --expand -d levels.mousebrains.com,levels-test.wkcc.org,levels.wkcc.org —
    # BEFORE nginx reload on prod, else TLS handshake fails for clients resolving via the new CNAME.
    server_name levels.mousebrains.com levels-test.wkcc.org levels.wkcc.org;
    return 301 https://$host$request_uri;
}

server {
    listen [::]:443 ssl ipv6only=on; # managed by Certbot
    listen 443 ssl; # managed by Certbot
    http2 on;

    ssl_certificate /etc/letsencrypt/live/levels.mousebrains.com/fullchain.pem; # managed by Certbot
    ssl_certificate_key /etc/letsencrypt/live/levels.mousebrains.com/privkey.pem; # managed by Certbot
    include /etc/letsencrypt/options-ssl-nginx.conf; # managed by Certbot
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem; # managed by Certbot

    # OCSP stapling — cache the CA's revocation status so clients don't have to
    # fetch it themselves on the TLS handshake.
    ssl_stapling on;
    ssl_stapling_verify on;
    resolver 1.1.1.1 8.8.8.8 valid=300s;
    resolver_timeout 5s;

    # SAN must cover all three before nginx reload — see the redirect block above.
    server_name levels.mousebrains.com levels-test.wkcc.org levels.wkcc.org;

    # Hide server identity completely (requires libnginx-mod-http-headers-more-filter)
    server_tokens off;
    more_clear_headers Server;

    # Security headers (server-level — apply when no location overrides)
    include /etc/nginx/snippets/security-headers.conf;

    # Document root — where build output + PHP symlinks live
    root /home/pat/public_html;
    index index.html;

    # Request size limit — no file uploads expected
    client_max_body_size 16k;

    # Gzip — big win for the inline-SVG HTML pages
    gzip on;
    gzip_types text/plain text/css text/csv
               application/json application/javascript
               image/svg+xml;
    gzip_min_length 256;
    gzip_vary on;

    # Restrict HTTP methods to GET, HEAD, POST
    if ($request_method !~ ^(GET|HEAD|POST)$) {
        return 405;
    }

    # Block known malicious scanners and exploit tools.
    # Claude-SearchBot / ClaudeBot are included because they ignore robots.txt
    # and generate enough hourly traffic to distort pipeline-freshness signals
    # without ever being useful to our readers.
    if ($http_user_agent ~* (zgrab|masscan|scanner/1\.0|libredtail|xfa1|Gh0st|^Hello|nvdorz|FreePBX-Scanner|Claude-SearchBot|ClaudeBot|r00ts3c|Scrapy|python-requests)) {
        return 444;
    }

    # Legacy URL redirects: pre-2026 levels.wkcc.org used /?P=<State>.html,
    # /?D=<id>, /?f=<id>, /?g=<id>, /?t=<id>, and /?d. The new site uses
    # different paths and IDs with no clean translation, so bounce all of
    # these to the site root. Browsers preserve any #A<id> fragment across
    # the redirect; the new site doesn't define those anchors so they're
    # silently ignored. 301 (permanent) so search engines/bookmarks update.
    if ($request_uri ~ "^/\?(P|D|f|g|t|d)(=|&|$)") {
        return 301 $scheme://$host/;
    }

    # Block dotfiles (.git, .env, .htaccess, etc.)
    location ~ /\. {
        deny all;
        return 404;
    }

    # Block access to PHP includes (db.php, svg_plot.php, etc.)
    # Use regex to override the \.php$ location (regex precedence rules)
    location ~ ^/includes/ {
        deny all;
        return 404;
    }

    # Static assets — long cache, immutable content (content-hashed where
    # mutable, e.g. style-<hash>.css; legacy unhashed assets still benefit
    # from a long max-age via periodic CSS-hash / JS-version URL churn).
    location /static/ {
        expires 365d;
        add_header Cache-Control "public, max-age=31536000, immutable";
        include /etc/nginx/snippets/security-headers.conf;
    }

    # Dynamic per-reach status, refreshed by every hourly pipeline run.
    # Exact match wins over the /static/ prefix and overrides the immutable
    # policy with a short TTL. Both expires and add_header must be explicit
    # here because nginx's add_header does not inherit from an ancestor block
    # once this block sets its own.
    location = /static/reaches-state.json {
        expires 5m;
        add_header Cache-Control "public, max-age=300";
        include /etc/nginx/snippets/security-headers.conf;
    }

    # Sparkline SVGs, keyed by gauge_id and regenerated by every hourly
    # pipeline run. Same override pattern as reaches-state.json above —
    # the parent /static/ immutable policy is wrong here because gauge ids
    # get reassigned when reaches are rewired (e.g. reach 104 moved from
    # gauge 139 to 185 on 2026-04-23), leaving stale caches that point to
    # ids the new index.html no longer references. 1h is plenty: sparklines
    # are a trend, a single missing 15-min point is invisible.
    location = /static/sparklines.json {
        expires 1h;
        add_header Cache-Control "public, max-age=3600";
        include /etc/nginx/snippets/security-headers.conf;
    }

    # Service worker — cached by the browser but always revalidated so SW
    # updates propagate immediately rather than lagging by expires 5m.
    location = /sw.js {
        add_header Cache-Control "no-cache";
        include /etc/nginx/snippets/security-headers.conf;
    }

    # Generated HTML/CSV/text pages — short cache, regenerated hourly.
    # limit_req zone=global protects against crawl bursts; burst=40 absorbs
    # normal page-load bursts where a client fetches the table + sparklines +
    # icons + static assets together.
    location / {
        limit_req zone=global burst=40 nodelay;
        try_files $uri $uri/ =404;
        expires 5m;
        add_header Cache-Control "public";
        include /etc/nginx/snippets/security-headers.conf;
    }

    # PHP endpoints via php-fpm
    location ~ \.php$ {
        limit_req zone=php burst=20 nodelay;
        try_files $uri =404;
        fastcgi_pass unix:/run/php/php-fpm.sock;
        fastcgi_index index.php;
        fastcgi_param SCRIPT_FILENAME $document_root$fastcgi_script_name;
        include fastcgi_params;

        # Pass environment to PHP
        fastcgi_param SQLITE_PATH /home/pat/DB/kayak.db;
        fastcgi_param EDITOR_FEATURE $editor_feature;
        fastcgi_param TURNSTILE_SITE_KEY $turnstile_site_key;
        fastcgi_param MAIL_FROM $mail_from;
        fastcgi_param SITE_URL $site_url;

        # Cache PHP responses (5 min for reads, no cache for edits)
        add_header Cache-Control "public, max-age=300";
        include /etc/nginx/snippets/security-headers.conf;
    }

    # Edit endpoint — rate-limited, no cache
    location = /edit.php {
        limit_req zone=edit burst=2 nodelay;
        try_files $uri =404;
        fastcgi_pass unix:/run/php/php-fpm.sock;
        fastcgi_param SCRIPT_FILENAME $document_root$fastcgi_script_name;
        include fastcgi_params;
        fastcgi_param SQLITE_PATH /home/pat/DB/kayak.db;
        fastcgi_param EDITOR_FEATURE $editor_feature;
        # edit.php uses the editor session cookie (ed_sess) for maintainer
        # auth after Phase 6 of the 2026-04-22 plan; no EDIT_PASSWORD is
        # required or consumed. EDITOR_FEATURE must be "1" on this host so
        # maintainers can reach /login.php to obtain the cookie.
        add_header Cache-Control "no-cache, no-store";
        include /etc/nginx/snippets/security-headers.conf;
    }

    # Auth endpoints — stricter rate limit (zone=auth, 3/min), no cache.
    # /login.php uses the Turnstile-enabled CSP variant so the widget can load.
    location = /login.php { limit_req zone=auth burst=2 nodelay;
        try_files $uri =404;
        fastcgi_pass unix:/run/php/php-fpm.sock;
        fastcgi_param SCRIPT_FILENAME $document_root$fastcgi_script_name;
        include fastcgi_params;
        fastcgi_param SQLITE_PATH /home/pat/DB/kayak.db;
        fastcgi_param EDITOR_FEATURE $editor_feature;
        fastcgi_param TURNSTILE_SITE_KEY $turnstile_site_key;
        fastcgi_param MAIL_FROM $mail_from;
        fastcgi_param SITE_URL $site_url;
        add_header Cache-Control "no-store";
        include /etc/nginx/snippets/security-headers-turnstile.conf;
    }
    location = /auth.php { limit_req zone=auth burst=2 nodelay;
        try_files $uri =404;
        fastcgi_pass unix:/run/php/php-fpm.sock;
        fastcgi_param SCRIPT_FILENAME $document_root$fastcgi_script_name;
        include fastcgi_params;
        fastcgi_param SQLITE_PATH /home/pat/DB/kayak.db;
        fastcgi_param EDITOR_FEATURE $editor_feature;
        add_header Cache-Control "no-store";
        include /etc/nginx/snippets/security-headers.conf;
    }
    location = /logout.php { limit_req zone=auth burst=2 nodelay;
        try_files $uri =404;
        fastcgi_pass unix:/run/php/php-fpm.sock;
        fastcgi_param SCRIPT_FILENAME $document_root$fastcgi_script_name;
        include fastcgi_params;
        fastcgi_param SQLITE_PATH /home/pat/DB/kayak.db;
        fastcgi_param EDITOR_FEATURE $editor_feature;
        add_header Cache-Control "no-store";
        include /etc/nginx/snippets/security-headers.conf;
    }
    location = /account.php { limit_req zone=php burst=5 nodelay;
        try_files $uri =404;
        fastcgi_pass unix:/run/php/php-fpm.sock;
        fastcgi_param SCRIPT_FILENAME $document_root$fastcgi_script_name;
        include fastcgi_params;
        fastcgi_param SQLITE_PATH /home/pat/DB/kayak.db;
        fastcgi_param EDITOR_FEATURE $editor_feature;
        add_header Cache-Control "no-store";
        include /etc/nginx/snippets/security-headers.conf;
    }

    # Phase 2 editor endpoints — no cache; auth enforced in PHP
    location = /propose.php { limit_req zone=php burst=5 nodelay;
        try_files $uri =404;
        fastcgi_pass unix:/run/php/php-fpm.sock;
        fastcgi_param SCRIPT_FILENAME $document_root$fastcgi_script_name;
        include fastcgi_params;
        fastcgi_param SQLITE_PATH /home/pat/DB/kayak.db;
        fastcgi_param EDITOR_FEATURE $editor_feature;
        fastcgi_param SITE_URL $site_url;
        fastcgi_param MAIL_FROM $mail_from;
        add_header Cache-Control "no-store";
        include /etc/nginx/snippets/security-headers.conf;
    }
    location = /comment.php { limit_req zone=php burst=5 nodelay;
        try_files $uri =404;
        fastcgi_pass unix:/run/php/php-fpm.sock;
        fastcgi_param SCRIPT_FILENAME $document_root$fastcgi_script_name;
        include fastcgi_params;
        fastcgi_param SQLITE_PATH /home/pat/DB/kayak.db;
        fastcgi_param EDITOR_FEATURE $editor_feature;
        fastcgi_param SITE_URL $site_url;
        fastcgi_param MAIL_FROM $mail_from;
        add_header Cache-Control "no-store";
        include /etc/nginx/snippets/security-headers.conf;
    }
    # Anonymous contact form — Turnstile-gated, auth rate limit, Turnstile CSP
    location = /contact.php { limit_req zone=auth burst=2 nodelay;
        try_files $uri =404;
        fastcgi_pass unix:/run/php/php-fpm.sock;
        fastcgi_param SCRIPT_FILENAME $document_root$fastcgi_script_name;
        include fastcgi_params;
        fastcgi_param SQLITE_PATH /home/pat/DB/kayak.db;
        fastcgi_param EDITOR_FEATURE $editor_feature;
        fastcgi_param TURNSTILE_SITE_KEY $turnstile_site_key;
        fastcgi_param MAIL_FROM $mail_from;
        fastcgi_param SITE_URL $site_url;
        add_header Cache-Control "no-store";
        include /etc/nginx/snippets/security-headers-turnstile.conf;
    }
    location = /review.php { limit_req zone=php burst=5 nodelay;
        try_files $uri =404;
        fastcgi_pass unix:/run/php/php-fpm.sock;
        fastcgi_param SCRIPT_FILENAME $document_root$fastcgi_script_name;
        include fastcgi_params;
        fastcgi_param SQLITE_PATH /home/pat/DB/kayak.db;
        fastcgi_param EDITOR_FEATURE $editor_feature;
        fastcgi_param SITE_URL $site_url;
        fastcgi_param MAIL_FROM $mail_from;
        add_header Cache-Control "no-store";
        include /etc/nginx/snippets/security-headers.conf;
    }
    location = /admin.php { limit_req zone=php burst=5 nodelay;
        try_files $uri =404;
        fastcgi_pass unix:/run/php/php-fpm.sock;
        fastcgi_param SCRIPT_FILENAME $document_root$fastcgi_script_name;
        include fastcgi_params;
        fastcgi_param SQLITE_PATH /home/pat/DB/kayak.db;
        fastcgi_param EDITOR_FEATURE $editor_feature;
        add_header Cache-Control "no-store";
        include /etc/nginx/snippets/security-headers.conf;
    }

    # Let's Encrypt ACME challenge
    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    # security.txt (RFC 9116) — beats the dotfile-block regex via exact match.
    location = /.well-known/security.txt {
        alias /home/pat/kayak/static/security.txt;
        add_header Cache-Control "public, max-age=86400";
    }

    # Legacy path — some tools still probe /security.txt directly.
    location = /security.txt {
        return 301 /.well-known/security.txt;
    }

    # Custom error page
    error_page 404 /404.html;
    location = /404.html {
        internal;
    }

    # Logging — kayak_timed format (defined in conf.d/kayak-log-format.conf)
    # adds rt=$request_time urt=$upstream_response_time so logs.analyze/analyze.py can
    # compute per-route latency quantiles.
    access_log /var/log/nginx/kayak-access.log kayak_timed;
    error_log  /var/log/nginx/kayak-error.log;
}
