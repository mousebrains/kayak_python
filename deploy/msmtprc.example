# System-wide msmtp config for outgoing mail via Gmail
# After install, replace APP_PASSWORD_HERE with your Gmail app password.
# Permissions: 640 root:msmtp
defaults
auth           on
tls            on
tls_trust_file /etc/ssl/certs/ca-certificates.crt
syslog         on

account        gmail
host           smtp.gmail.com
port           587
tls_starttls   on
from           pat.kayak@gmail.com
user           pat.kayak@gmail.com
password       APP_PASSWORD_HERE

account default : gmail

aliases        /etc/msmtp-aliases
