  set colInfo(class_flow) {text comment 'Level dependent river classification'}
  set colInfo(date) {timestamp comment 'Modification time'}
  set colInfo(data_source) {text}
  set colInfo(db_name) {text}
  set colInfo(db_source) {text}
  set colInfo(description) {text comment 'Description of river segment'}
  set colInfo(difficulties) {text comment 'Difficulties encountered on this section'}
  set colInfo(display_name) {text comment 'Name displayed for this section'}
  set colInfo(drainage) {text comment 'Which drainage is this section in?'}
  set colInfo(drainage_area) {text comment 'Area of this drainage'}
  set colInfo(elevation) {text comment 'Altitude of gauge'}
  set colInfo(elevation_lost) {text comment 'Feet lost in this section'}
  set colInfo(email) {text comment 'E-Mail address of person who changed the record'}
  set colInfo(features) {text comment 'Interesting features on this segment'}
  set colInfo(gauge_location) {text comment 'Location of gauge'}
  set colInfo(gradient) {text comment 'Feet/Mile for this segment'}
  set colInfo(guide_book) {text comment 'Guide book reference'}
  set colInfo(high_flow) {text comment 'High flow level'}
  set colInfo(low_flow) {text comment 'Low flow level'}
  set colInfo(optimal_flow) {text comment 'Optimal level for running this segment'}
  set colInfo(bank_full) {text comment 'Bank full level for this segment'}
  set colInfo(flood_stage) {text comment 'Flood stage for this segment'}
  set colInfo(latitude) {text comment 'Latitude of segment'}
  set colInfo(longitude) {text comment 'Longitude of segment'}
  set colInfo(length) {text comment 'Length of segment in miles'}
  set colInfo(map_name) {text comment 'Name of map file for this record'}
  set colInfo(merged_dbs) {text comment 'databases used to construct this gauge'}
  set colInfo(name) {text comment 'Name of person who changed the record'}
  set colInfo(no_show) {text comment 'Do not display this record'}
  set colInfo(notes) {text comment 'Notes describing this section'}
  set colInfo(page_#) {text comment 'Guide book page number'}
  set colInfo(region) {text comment 'Region within a state this section is in'}
  set colInfo(remoteness) {text comment 'How remote is this section'}
  set colInfo(river_name) {text comment 'Name to display for the river name for this section'}
  set colInfo(run_#) {text comment 'Run number in guide book'}
  set colInfo(scenery) {text comment 'Type of scenery on this section'}
  set colInfo(season) {text comment 'Which season is the section runable'}
  set colInfo(section) {text comment 'Section name for this record'}
  set colInfo(sort_key) {text comment 'How to sort this entry'}
  set colInfo(source_name) {text comment 'Data source name'}
  set colInfo(state) {text comment 'State(s) this segment is located in'}
  set colInfo(station_#) {text comment 'USGS Station ID number'}
  set colInfo(geos_id) {text comment 'GEOS gauge ID'}
  set colInfo(usgs_id) {text comment 'USGS gauge ID number'}
  set colInfo(nwsli_id) {text comment 'NWS gauge ID'}
  set colInfo(cbtt_id) {text comment 'CBTT gauge ID'}
  set colInfo(nws_id) {text comment 'NWS(from CBTT) gauge ID'}
  set colInfo(snotel_id) {text comment 'SNOTEL gauge ID'}
  set colInfo(userName) {text comment 'Username of person who edited this entry'}
  set colInfo(watershed_type) {text comment 'Type of watershed'}

  proc colName {name} {
    variable remap
    if {[info exists remap($name)]} {return $remap($name)}
    return $name
  }

  proc colDefinitions {fp} {
    variable colInfo

    foreach field [lsort [array names colInfo]] {
      set name $field
      set name [process::colName $field]
      puts $fp " , $name $colInfo($field)"
    }
  }

  proc File {filename table mergedMaster} {
    variable colInfo
    variable exclude
    variable xlat
  
    if {[info exists keys]} {unset keys}
    source [file join $::dbDir $filename]
  
    set keys [info vars]
    
    foreach key $keys {
      if {[lsearch $exclude $key] != -1} continue
      upvar 0 $key a
      if {![array exists a]} continue
      set values ""
      set columns ""
      set delim ""
      foreach field [array names a] {
        if {$a($field) == ""} continue;
        set name [string tolower $field];
        if {[info exists colInfo($name)]} {
          set name [colName $name]
          if {$field == "date"} { 
            set seconds [clock scan "$a($field)"]
            set a($field) [clock format $seconds -format "%Y%m%d%H%M%S"]
          } elseif {$name == "class_flow"} {
            set a($field) [join $a($field) ","]
          } elseif {$name == "sort_key"} {
	    set a($field) [info::sortKey $key]
	  }
 
          if {[string match "*_flow" $name]} {
            regsub -all "\[']" $a($field) "ft" a($field)
          }

          if {[lsearch $xlat $name] != -1} { 
            regsub -all "\[\.-]" $a($field) "_" a($field)
          }
          regsub -all "'" $a($field) "" value
          append values "$delim'$value'"
          set delim ", "
          lappend columns $name
        } elseif {$name == "calculation"} {
          calc::parse $a($field)
          set time $calc::timeStack
          set expr "round(greatest(0, [lindex $calc::stack 0]))"
          append values "$delim'$time', '$expr'"
          set delim ", "
          lappend columns calc_time calc_expr
        } else {
          puts stderr "Unrecognized column name ${field}($name), found for key $key in file $filename"
          exit 1
        }
      }
      if {$columns != ""} {
        set hash [hashValue $key]
        puts "insert into $table (HashValue, Approved, [join $columns ","]) values ('$hash', '1', $values)"
	puts " on duplicate key update"
	set delim ""
	foreach col $columns {
          puts "  $delim$col=values($col)"
          set delim ","
        }
        puts ";"

        if {$mergedMaster != ""} {
          puts "insert into $mergedMaster (HashValue, [join $columns ","]) values ('$hash', $values)"
          puts " on duplicate key update"
          set delim ""
          foreach col $columns {
            puts "  $delim$col=values($col)"
            set delim ","
          }
          puts ";"
        }
      }
      unset $key
    }
  }
}

