  set colInfo(calculate_result) {text comment 'Type of information generated for derived information'}
  set colInfo(calc_expr) {text comment 'Expression for calculating derived information value'}
  set colInfo(calc_notes) {text comment 'Notes about calculation'}
  set colInfo(calc_time) {text comment 'Expression for calculating derived information time stamp'}
